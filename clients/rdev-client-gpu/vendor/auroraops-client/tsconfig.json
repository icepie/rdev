{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["es2020", "dom", "es6"],
    "module": "commonjs",
    "rootDir": "ts",
    "outDir": "www/static",
    "sourceMap": false,
    "strict": false,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictPropertyInitialization": false
  },
  "include": [
    "ts/**/*.ts"
  ]
}
