[Unit]
Description=AuroraOps Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStartPre=-/opt/auroraops/auroraops-uinput-setup
ExecStart=/opt/auroraops/auroraops-agent --service --config /etc/auroraops/agent-config.json --port 18765
Restart=always
RestartSec=5
User=root
WorkingDirectory=/opt/auroraops

[Install]
WantedBy=multi-user.target
